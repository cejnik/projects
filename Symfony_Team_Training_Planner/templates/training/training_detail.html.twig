{% extends 'base.html.twig' %}

{% block title %}{{ training.title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/training-detail.css') }}">
{% endblock %}

{% block body %}
    <main class="training-detail-page">
        <a class="training-detail-back" href="{{ path('app_training_index') }}">Back to training board</a>

        <article class="training-detail-card">
            <header class="training-detail-header">
                <span class="training-detail-badge">Session detail</span>
                <h1 class="training-detail-title">{{ training.title }}</h1>
                <p class="training-detail-description">
                    {{ training.description ?: 'No extra description was added for this session yet.' }}
                </p>
            </header>

            <section class="training-detail-body">
                <div class="training-detail-row">
                    <span class="training-detail-label">Scheduled for</span>
                    <span class="training-detail-value">{{ training.scheduledAt|date('d.m.Y H:i') }}</span>
                </div>
                <div class="training-detail-row">
                    <span class="training-detail-label">Location</span>
                    <span class="training-detail-value">{{ training.location }}</span>
                </div>
                <div class="training-detail-row">
                    <span class="training-detail-label">Open spots</span>
                    {% if remainingSpots == 0 %}
                        <span class="training-detail-value">Fully booked</span>
                    {% else %}
                        <span class="training-detail-value">{{remainingSpots}}/{{training.capacity}}</span>
                    {% endif %}
                </div>
                <div class="training-detail-row">
                    <span class="training-detail-label">Coach</span>
                    <span class="training-detail-value">{{ training.coach.email }}</span>
                </div>
                <div class="training-detail-row">
                    <span class="training-detail-label">Created</span>
                    <span class="training-detail-value">{{ training.createdAt|date('d.m.Y H:i') }}</span>
                </div>
                <div class="training-detail-row">
                    <span class="training-detail-label">Last update</span>
                    <span class="training-detail-value">{{ training.updatedAt|date('d.m.Y H:i') }}</span>
                </div>


                <div class="training-detail-actions">
                    {% if remainingSpots !== 0 %}
                        {% if  isJoined == false %}
                            <form action="{{ path('app_training_join', { id: training.id }) }}" method="post">
                                <input type="hidden" name="_token" value="{{ csrf_token('join_training_' ~ training.id) }}">
                                <button class="training-detail-join" type="submit">Join training</button>
                            </form>
                        {% else %}
                            <form action="{{ path('app_training_leave', { id: training.id }) }}" method="post">
                                <input type="hidden" name="_token" value="{{ csrf_token('leave_training_' ~ training.id) }}">
                                <button class="training-detail-leave" type="submit">Leave training</button>
                            </form>
                        {% endif %}
                    {% endif %}

                    {% if is_granted('ROLE_USER') and app.user == training.coach %}
                        <form action="{{ path('app_training_delete', { id: training.id }) }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_training_' ~ training.id) }}">
                            <button class="training-detail-delete" type="submit">Delete training</button>
                        </form>
                    {% endif %}
                </div>
            </section>
        </article>

        <section id="comments" class="training-comments">
            <div class="training-comments__header">
                <div>
                    <span class="training-comments__kicker">Discussion</span>
                    <h2 class="training-comments__title">Comments</h2>
                </div>
                <span class="training-comments__count">{{ training.comments|length }} total</span>
            </div>

            <div class="training-comments__composer">
                {{ form_start(commentForm, {
                    action: path('app_training_comment_add', { id: training.id })
                }) }}
                    <div class="training-comments__form">
                        {{ form_row(commentForm.content) }}
                        <div class="training-comments__form-actions">
                            <button class="training-comments__submit" type="submit">Add comment</button>
                        </div>
                    </div>
                {{ form_end(commentForm) }}
            </div>

            {% if training.comments is not empty %}
                <div class="training-comments__list">
                    {% for comment in training.comments %}
                        <article class="training-comment">
                            <div class="training-comment__meta">
                                <strong class="training-comment__author">{{ comment.author.email }}</strong>
                                <span class="training-comment__time">{{ comment.createdAt|date('d.m.Y H:i') }}</span>
                            </div>
                            <p class="training-comment__content">{{ comment.content }}</p>
                        </article>
                    {% endfor %}
                </div>
            {% else %}
                <div class="training-comments__empty">
                    <p>No comments yet. Start the conversation.</p>
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}
